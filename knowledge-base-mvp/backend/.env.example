# --- Environment ---
ENVIRONMENT=DEV

# --- OpenAI ---
# Required for embeddings and streaming chat
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Pluggable Providers ---
# Options: chroma | databricks
VECTOR_PROVIDER=chroma
# Options: delta_local | databricks
METADATA_PROVIDER=delta_local

# --- Databricks Settings (only if provider=databricks) ---
DATABRICKS_HOST=https://dbc-XXXXXXX-XXXX.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_SQL_HTTP_PATH=/sql/1.0/warehouses/XXXXXXXXXXXXXXXX
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=banking_schema
DATABRICKS_VECTOR_SEARCH_ENDPOINT=bank_knowledge_endpoint
DATABRICKS_VECTOR_INDEX_NAME=main.banking_schema.bank_knowledge_index
